# Storage Configuration - .env.example

# ============================================
# STORAGE PROVIDER CONFIGURATION
# ============================================

# Choose storage provider: r2, s3, or cloudinary
# Default: r2
STORAGE_PROVIDER=r2

# ============================================
# CLOUDFLARE R2 CONFIGURATION
# ============================================
# Get these credentials from Cloudflare Dashboard > R2 > API Tokens

# Your Cloudflare Account ID
# Found in Cloudflare Dashboard URL: https://dash.cloudflare.com/{ACCOUNT_ID}
CLOUDFLARE_ACCOUNT_ID=

# API Token with R2 permissions
# Create at: https://dash.cloudflare.com/?to=/:account/r2/tokens/create
CLOUDFLARE_ACCESS_KEY_ID=

# API Token Secret (shown only once during creation)
CLOUDFLARE_ACCESS_KEY_SECRET=

# R2 Bucket name
# Default: classes360
CLOUDFLARE_BUCKET_NAME=classes360

# Public URL for R2 bucket
# Format: https://{bucket_name}.{account_id}.r2.dev
# Or use a custom domain if configured
CLOUDFLARE_R2_PUBLIC_URL=https://classes360.123abc.r2.dev

# ============================================
# AWS S3 CONFIGURATION (Future)
# ============================================
# Only needed if using S3 provider

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_PUBLIC_URL=

# ============================================
# CLOUDINARY CONFIGURATION (Future)
# ============================================
# Only needed if using Cloudinary provider

CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_PRESET=

# ============================================
# FILE UPLOAD SETTINGS
# ============================================

# Maximum image file size (bytes)
MAX_IMAGE_SIZE=2097152

# Maximum document file size (bytes)
MAX_DOCUMENT_SIZE=10485760

# Allowed image MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Allowed document MIME types (comma-separated)
ALLOWED_DOCUMENT_TYPES=application/pdf
